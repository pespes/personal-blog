---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt: string;
  caption?: string;
  width?: number;
  class?: string;
}

const { src, alt, caption, width = 900, class: className } = Astro.props;
const isRemote = typeof src === "string";
---

<figure class:list={["my-6", className]}>
  {
    isRemote ? (
      <img
        src={src as string}
        alt={alt}
        width={width}
        loading="lazy"
        decoding="async"
        class="w-full rounded-lg"
      />
    ) : (
      <Image
        src={src as ImageMetadata}
        alt={alt}
        width={width}
        class="w-full rounded-lg"
      />
    )
  }
  {
    caption && (
      <figcaption class="mt-2 text-center text-sm text-foreground/60">
        {caption}
      </figcaption>
    )
  }
</figure>
